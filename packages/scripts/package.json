{
  "name": "@latimeria/latimeria-cli",
  "version": "0.1.0",
  "description": "A supporting tools for developing latimeria",
  "license": "Apache-2.0 AND MIT",
  "type": "module",
  "main": "dist/cjs/latimeria.cjs",
  "bin": {
    "latimeria": "dist/cjs/latimeria.cjs"
  },
  "private": true,
  "scripts": {
    "syncPublic": "tsx bin/latimeria.ts",
    "typecheck": "tsc --noEmit",
    "dev": "rslib build --watch",
    "build": "rslib build",
    "gen:openapi": "openapi-typescript http://localhost:8787/openapi -o src/generated/openapi.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kanium3/YSF17_SchoolFestival.git"
  },
  "dependencies": {
    "@google-cloud/local-auth": "^3.0.1",
    "c12": "4.0.0-beta.4",
    "citty": "^0.2.1",
    "es-toolkit": "^1.45.1",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "mime": "^4.1.0",
    "openapi-fetch": "^0.17.0",
    "openapi-typescript": "^7.13.0",
    "pathe": "^2.0.3",
    "pouchdb": "^9.0.0"
  },
  "devDependencies": {
    "@rslib/core": "catalog:",
    "@tsconfig/node-lts": "^24.0.0",
    "@types/node": "^25.5.0",
    "@types/pouchdb": "^6.4.2",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
